<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:layout_width="fill_parent" android:layout_height="fill_parent" android:fillViewport="true"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:padding="24.0dip" android:layout_width="fill_parent" android:layout_height="wrap_content">
        <TextView android:textSize="24.0sp" android:textStyle="bold" android:layout_width="fill_parent" android:layout_height="wrap_content" android:text="TapTaxi Activation" />
        <TextView android:textSize="16.0sp" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="12.0dip" android:text="Send your Device ID to admin bot, then enter the license code." />
        <TextView android:id="@id/device_id_value" android:background="#11000000" android:padding="12.0dip" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="16.0dip" android:textIsSelectable="true" />
        <Button android:id="@id/button_copy_id" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="12.0dip" android:text="Copy Device ID" android:onClick="onCopyDeviceId" />
        <EditText android:id="@id/license_code_input" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="20.0dip" android:hint="License code" android:maxLength="32" android:inputType="textCapCharacters|textNoSuggestions" />
        <Button android:id="@id/button_activate" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginTop="12.0dip" android:text="Activate" android:onClick="onActivate" />
    </LinearLayout>
</ScrollView>
